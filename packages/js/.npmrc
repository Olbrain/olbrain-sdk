# NPM Configuration for @olbrain organization
# This file configures how npm publishes packages to the @olbrain organization

# Set the registry for @olbrain scoped packages
@olbrain:registry=https://registry.npmjs.org/

# Ensure public access for organization packages
access=public

# Optional: Add your npm token here (keep this private!)
# //registry.npmjs.org/:_authToken=YOUR_NPM_TOKEN_HERE
