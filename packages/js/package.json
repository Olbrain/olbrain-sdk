{
  "name": "@olbrain/js-sdk",
  "version": "1.1.0",
  "description": "Official JavaScript SDK for Olbrain Agent Cloud - one-line integration for AI agent chatbots",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "browser": "./dist/index.global.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.global.js",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./widget": {
      "types": "./dist/widget.d.ts",
      "default": "./dist/widget.global.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "olbrain",
    "agent",
    "ai",
    "chat",
    "sdk",
    "javascript",
    "typescript",
    "chatbot",
    "chatwidget"
  ],
  "author": "Olbrain",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Olbrain/olbrain-sdk.git",
    "directory": "packages/js"
  },
  "homepage": "https://github.com/Olbrain/olbrain-sdk/tree/main/packages/js#readme",
  "bugs": {
    "url": "https://github.com/Olbrain/olbrain-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "marked": "^11.0.0",
    "highlight.js": "^11.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/ui": "^1.0.0",
    "jsdom": "^28.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "optionalDependencies": {
    "eventsource": "^2.0.2"
  }
}
